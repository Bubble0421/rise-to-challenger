# Copy this file to `.env` before running the app.
# The dashboard loads `.env` automatically on startup.

# Riot Games API
# Get a free development key at https://developer.riotgames.com/
# Development keys expire regularly and need to be refreshed.
RIOT_API_KEY=RGAPI-your-key-here

# Optional runtime settings
RIOT_REGION=na1
RIOT_REGIONAL=americas
DDRAGON_PATCH=16.7.1
DATA_PATCH_LABEL=16.6-16.7
PUBLIC_DEMO_MODE=false

# Optional local AI settings
OLLAMA_MODEL=gemma2:2b
EMBEDDING_MODEL=nomic-embed-text
CHROMA_DIR=data/chromadb
